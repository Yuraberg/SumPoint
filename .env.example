# ═══════════════════════════════════════════════════════════════════════════════
# SumPoint — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in all required values before first run.
#
# Generation hints:
#   openssl rand -hex 32     → 32-byte hex key (SECRET_KEY, SESSION_ENCRYPTION_KEY)
#   python generate_session.py → TELEGRAM_SESSION_STRING

# ── Telegram User API ──────────────────────────────────────────────────────────
# Obtain at https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Pre-generated Telethon session string (run: python generate_session.py).
# Preferred for Docker/Coolify deploys — avoids file-based session storage.
TELEGRAM_SESSION_STRING=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Token from @BotFather. The bot MUST be the same bot whose token is used for
# the Telegram Login Widget.
TELEGRAM_BOT_TOKEN=
# Bot username without "@", used to build deep links and Mini App buttons
TELEGRAM_BOT_USERNAME=SumProcPointBot

# ── DeepSeek AI ────────────────────────────────────────────────────────────────
# API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=
# Optional: model override (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat
# Optional: custom API endpoint (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Ollama (embeddings) ────────────────────────────────────────────────────────
# URL of the Ollama instance running BGE-M3 for vector embeddings.
# In Docker, use the host gateway (172.20.0.1 or host.docker.internal).
OLLAMA_BASE_URL=http://localhost:11434

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# asyncpg-compatible URL. The database and pgvector extension must exist.
DATABASE_URL=postgresql+asyncpg://sumpoint:sumpoint@localhost:5432/sumpoint

# ── Redis ──────────────────────────────────────────────────────────────────────
# Also used as the Celery broker and result backend — all services (api, bot,
# worker, beat) MUST point to the same Redis instance.
REDIS_URL=redis://localhost:6379/0

# ── Uptime Kuma ────────────────────────────────────────────────────────────────
# Push-monitor URL (Uptime Kuma → Add Monitor → Push type). If set, a periodic
# Celery task pings it every 5 min so Uptime Kuma can alert when the worker/beat
# stop ticking. Leave empty to disable.
UPTIME_KUMA_PUSH_URL=

# ── Auth & Security ────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256 session file encryption
# Generate: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=
# Secret key for JWT signing and Telegram Login Widget HMAC verification
# Generate: openssl rand -hex 32
# REQUIRED — no default, app will fail to start without it.
SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins for the frontend SPA. Must match the domain(s)
# where the frontend is hosted. Set to your production domain(s) before launch.
CORS_ORIGINS=["http://localhost:8000","http://localhost:8001"]

# ── Public app URL ─────────────────────────────────────────────────────────────
# CRITICAL — used to build the magic-link login URL sent via the bot and the
# Mini App button. Left at the localhost default in production, the bot
# message still arrives but its login link points nowhere reachable, which
# looks like "there's no link". MUST be your public https:// domain in
# production (Telegram WebApp also requires https).
APP_BASE_URL=http://localhost:8001

# ── Access control ────────────────────────────────────────────────────────────
# Without this, ANYONE with a Telegram account can register and start using
# your DeepSeek API key / Telethon session. Comma-separated Telegram user ids
# that always get instant access (bypass invite codes and manual approval) —
# put your own id here. Checked live on every request, so editing this list
# takes effect immediately without a database change. Everyone else who logs
# in needs a valid invite code (generate one with the bot's /invite command,
# owner-only) or waits for manual approval — see the "Доступ" page / bot DM.
OWNER_TELEGRAM_IDS=

# ── Digest schedule (UTC hours, 24h format) ────────────────────────────────────
DIGEST_MORNING_HOUR=8
DIGEST_EVENING_HOUR=20

# ── Continuous channel fetch + AI processing ───────────────────────────────────
# Runs every N minutes, processing a small batch of channels each time
# (oldest last_fetched_at first) to spread Telethon polling and avoid flood bans.
POSTS_FETCH_INTERVAL_MINUTES=20
POSTS_FETCH_BATCH_SIZE=20

# ── Duplicate clustering ───────────────────────────────────────────────────────
# Groups the same story reposted across channels via BGE-M3 embedding cosine
# similarity ("эта новость в N каналах"). Set CLUSTERING_ENABLED=false to skip.
# A new post joins a cluster if its nearest neighbour (same user's channels,
# within CLUSTER_WINDOW_DAYS) is at least CLUSTER_SIMILARITY_THRESHOLD similar.
# If BGE-M3/Ollama is down, embedding-less posts are simply left ungrouped.
CLUSTERING_ENABLED=true
CLUSTER_SIMILARITY_THRESHOLD=0.86
CLUSTER_WINDOW_DAYS=3

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use WARNING in production to reduce noise.
LOG_LEVEL=INFO

# ── Sentry (error tracking) ────────────────────────────────────────────────────
# Optional. Get a DSN at https://sentry.io → Create Project → FastAPI.
# Leave empty to disable Sentry entirely.
SENTRY_DSN=

# ── Debug ──────────────────────────────────────────────────────────────────────
# Set to "true" to enable debug mode (more verbose errors, auto-reload, etc.)
DEBUG=false
