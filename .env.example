# ── Telegram User API ──────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sumpoint:sumpoint@localhost:5432/sumpoint

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Security ───────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256 session encryption  (generate: openssl rand -hex 32)
SESSION_ENCRYPTION_KEY=
# Secret for JWT / Telegram Login Widget signature
SECRET_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Digest schedule (cron) ─────────────────────────────────────────────────────
DIGEST_MORNING_HOUR=8
DIGEST_EVENING_HOUR=20
