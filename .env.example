# ── Telegram User API ──────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Pre-generated Telethon session string (see generate_session.py). Preferred
# for Docker/Coolify deploys — avoids file-based session storage.
TELEGRAM_SESSION_STRING=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Bot username without "@", used to build links shown to users
TELEGRAM_BOT_USERNAME=SumProcPointBot

# ── DeepSeek ───────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── Ollama (embeddings) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sumpoint:sumpoint@localhost:5432/sumpoint

# ── Redis ──────────────────────────────────────────────────────────────────────
# Also used as the Celery broker/result backend.
REDIS_URL=redis://localhost:6379/0

# ── Uptime Kuma ────────────────────────────────────────────────────────────────
# Push-monitor URL (Uptime Kuma → Add Monitor → Push). Leave empty to disable.
UPTIME_KUMA_PUSH_URL=

# ── Security ───────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256 session encryption  (generate: openssl rand -hex 32)
SESSION_ENCRYPTION_KEY=
# Secret for JWT / Telegram Login Widget signature — required, no default.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins for the frontend.
CORS_ORIGINS=["http://localhost:8000","http://localhost:8001"]

# ── Public app URL ─────────────────────────────────────────────────────────────
# Used in magic-link login URLs and the bot's Mini App button. Must be https
# in production (Telegram WebApp requirement).
APP_BASE_URL=http://localhost:8001

# ── Digest schedule (UTC hours) ────────────────────────────────────────────────
DIGEST_MORNING_HOUR=8
DIGEST_EVENING_HOUR=20

# ── Continuous channel fetch + AI processing + embeddings ──────────────────────
# Runs every N minutes, processing a small batch of channels each time
# (oldest last_fetched_at first) to keep Telethon polling spread out.
POSTS_FETCH_INTERVAL_MINUTES=20
POSTS_FETCH_BATCH_SIZE=20

# ── Debug ──────────────────────────────────────────────────────────────────────
DEBUG=false
